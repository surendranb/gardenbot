# GardenBot Secrets Configuration
# Replace the value below with your GitHub Personal Access Token (Classic)
# with "repo" scope if you intend to run gardenbot via headless cron.
GITHUB_TOKEN=your_pat_goes_here

# OpenRouter API Key for Cloud Reasoning
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Google API Key for Gemini Vision
GOOGLE_API_KEY=your_google_api_key_here
